# OpenDataWorks 容器环境配置
# 复制此文件为 deploy/.env 并根据实际环境修改

# 镜像版本（发布时与版本号一致，默认使用 Docker Hub 在线拉取）
# 离线部署包需在 deploy/.env 中设置（create-offline-package.sh 会自动处理）：
# OPENDATAWORKS_BACKEND_IMAGE=opendataworks-backend:0.9.0
# OPENDATAWORKS_FRONTEND_IMAGE=opendataworks-frontend:0.9.0
# OPENDATAWORKS_DATAAGENT_BACKEND_IMAGE=opendataworks-dataagent-backend:0.9.0

# 自定义 Docker 网络网段（建议按环境拆分，避免与宿主机/VPN 网段冲突）
OPENDATAWORKS_PROD_SUBNET=10.71.0.0/24
OPENDATAWORKS_PROD_GATEWAY=10.71.0.1
OPENDATAWORKS_DEV_SUBNET=10.72.0.0/24
OPENDATAWORKS_DEV_GATEWAY=10.72.0.1

# MySQL 配置（Compose 会读取这些变量）
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=opendataworks
MYSQL_USER=opendataworks
MYSQL_PASSWORD=opendataworks123

# 后端数据源（容器通过 env_file 注入）
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/opendataworks?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=opendataworks
SPRING_DATASOURCE_PASSWORD=opendataworks123

# 时区设置
TZ=Asia/Shanghai

# DataAgent（NL2SQL）配置
# 默认使用独立 dataagent 用户：对 opendataworks 只读，对 dataagent 会话库读写
# 若升级自旧版本且沿用已有 mysql-data volume，请先手动补建该用户后再切换
DATAAGENT_MYSQL_USER=dataagent
DATAAGENT_MYSQL_PASSWORD=dataagent123
DATAAGENT_MYSQL_DATABASE=opendataworks
DATAAGENT_SESSION_MYSQL_DATABASE=dataagent
# 生产容器默认以非 root 身份运行；如挂载目录权限不匹配，可改成宿主机目录拥有者的 UID/GID
DATAAGENT_RUNTIME_UID=1000
DATAAGENT_RUNTIME_GID=1000

# 挂载路径（相对于 deploy/）
# Skills 根目录：源码部署默认指向仓库内 dataagent/.claude/skills；离线包会自动改写到 deploy/dataagent-runtime/skills
DATAAGENT_SKILLS_DIR=../dataagent/.claude/skills
