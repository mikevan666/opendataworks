#!/bin/sh
set -eu

RAW_BASE_URL="${ODW_AGENT_API_BASE_URL:-${ODW_BACKEND_BASE_URL:-}}"
SERVICE_TOKEN="${ODW_AGENT_SERVICE_TOKEN:-}"
TIMEOUT_SECONDS="${ODW_AGENT_TIMEOUT_SECONDS:-${ODW_BACKEND_TIMEOUT_SECONDS:-30}}"
TOKEN_HEADER_NAME="${ODW_AGENT_SERVICE_TOKEN_HEADER_NAME:-X-Agent-Service-Token}"

usage() {
  cat >&2 <<'EOF'
Usage:
  odw-cli inspect [--database DB] [--table TABLE] [--keyword KEYWORD] [--table-limit N]
  odw-cli lineage [--table TABLE] [--db-name DB] [--table-id ID] [--depth N]
  odw-cli resolve-datasource --database DB [--preferred-engine mysql|doris]
  odw-cli export --kind tables|lineage|datasource [--database DB]
  odw-cli ddl [--database DB] [--table TABLE] [--table-id ID]
  odw-cli read-query --database DB --sql SQL [--preferred-engine mysql|doris] [--limit N] [--timeout-seconds N]
EOF
  exit 2
}

trim() {
  printf '%s' "$1" | awk '{$1=$1};1'
}

require_env() {
  name="$1"
  value="$2"
  if [ -z "$value" ]; then
    echo "$name is required" >&2
    exit 1
  fi
}

normalize_base_url() {
  value="$(trim "$1")"
  if [ -z "$value" ]; then
    echo ""
    return
  fi
  case "$value" in
    */metadata) printf '%s' "${value%/metadata}" ;;
    */metadata/) printf '%s' "${value%/metadata/}" ;;
    */query) printf '%s' "${value%/query}" ;;
    */query/) printf '%s' "${value%/query/}" ;;
    */v1/ai) printf '%s' "$value" ;;
    */v1/ai/) printf '%s' "${value%/}" ;;
    */api) printf '%s/v1/ai' "${value%/}" ;;
    *) printf '%s' "${value%/}" ;;
  esac
}

BASE_URL="$(normalize_base_url "$RAW_BASE_URL")"

request_get() {
  endpoint="$1"
  shift

  body_file="$(mktemp)"
  trap 'rm -f "$body_file"' EXIT INT TERM

  http_code="$(curl -sS -o "$body_file" -w '%{http_code}' \
    -H "Accept: application/json" \
    -H "${TOKEN_HEADER_NAME}: ${SERVICE_TOKEN}" \
    --max-time "$TIMEOUT_SECONDS" \
    -G "${BASE_URL%/}/${endpoint}" \
    "$@")"

  if [ "${http_code#2}" != "$http_code" ]; then
    cat "$body_file"
    rm -f "$body_file"
    trap - EXIT INT TERM
    exit 0
  fi

  if [ -s "$body_file" ]; then
    cat "$body_file" >&2
  else
    echo "agent api request failed: HTTP $http_code" >&2
  fi
  rm -f "$body_file"
  trap - EXIT INT TERM
  exit 1
}

request_post_json() {
  endpoint="$1"
  json_payload="$2"

  body_file="$(mktemp)"
  trap 'rm -f "$body_file"' EXIT INT TERM

  http_code="$(curl -sS -o "$body_file" -w '%{http_code}' \
    -H "Accept: application/json" \
    -H "Content-Type: application/json" \
    -H "${TOKEN_HEADER_NAME}: ${SERVICE_TOKEN}" \
    --max-time "$TIMEOUT_SECONDS" \
    -X POST "${BASE_URL%/}/${endpoint}" \
    -d "$json_payload")"

  if [ "${http_code#2}" != "$http_code" ]; then
    cat "$body_file"
    rm -f "$body_file"
    trap - EXIT INT TERM
    exit 0
  fi

  if [ -s "$body_file" ]; then
    cat "$body_file" >&2
  else
    echo "agent api request failed: HTTP $http_code" >&2
  fi
  rm -f "$body_file"
  trap - EXIT INT TERM
  exit 1
}

parse_inspect() {
  database=""
  table_name=""
  keyword=""
  table_limit=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --database) database="${2:-}"; shift 2 ;;
      --table) table_name="${2:-}"; shift 2 ;;
      --keyword) keyword="${2:-}"; shift 2 ;;
      --table-limit) table_limit="${2:-}"; shift 2 ;;
      *) echo "unknown inspect arg: $1" >&2; usage ;;
    esac
  done

  set --
  [ -n "$database" ] && set -- "$@" --data-urlencode "database=$database"
  [ -n "$table_name" ] && set -- "$@" --data-urlencode "table=$table_name"
  [ -n "$keyword" ] && set -- "$@" --data-urlencode "keyword=$keyword"
  [ -n "$table_limit" ] && set -- "$@" --data-urlencode "tableLimit=$table_limit"
  request_get "metadata/inspect" "$@"
}

parse_lineage() {
  table_name=""
  db_name=""
  table_id=""
  depth=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --table) table_name="${2:-}"; shift 2 ;;
      --db-name) db_name="${2:-}"; shift 2 ;;
      --table-id) table_id="${2:-}"; shift 2 ;;
      --depth) depth="${2:-}"; shift 2 ;;
      *) echo "unknown lineage arg: $1" >&2; usage ;;
    esac
  done

  set --
  [ -n "$table_name" ] && set -- "$@" --data-urlencode "table=$table_name"
  [ -n "$db_name" ] && set -- "$@" --data-urlencode "dbName=$db_name"
  [ -n "$table_id" ] && set -- "$@" --data-urlencode "tableId=$table_id"
  [ -n "$depth" ] && set -- "$@" --data-urlencode "depth=$depth"
  request_get "metadata/lineage" "$@"
}

parse_resolve_datasource() {
  database=""
  preferred_engine=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --database) database="${2:-}"; shift 2 ;;
      --preferred-engine|--engine) preferred_engine="${2:-}"; shift 2 ;;
      *) echo "unknown resolve-datasource arg: $1" >&2; usage ;;
    esac
  done

  [ -n "$database" ] || { echo "--database is required" >&2; usage; }

  set -- --data-urlencode "database=$database"
  [ -n "$preferred_engine" ] && set -- "$@" --data-urlencode "preferredEngine=$preferred_engine"
  request_get "metadata/datasource/resolve" "$@"
}

parse_export() {
  kind=""
  database=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --kind) kind="${2:-}"; shift 2 ;;
      --database) database="${2:-}"; shift 2 ;;
      *) echo "unknown export arg: $1" >&2; usage ;;
    esac
  done

  [ -n "$kind" ] || { echo "--kind is required" >&2; usage; }

  set -- --data-urlencode "kind=$kind"
  [ -n "$database" ] && set -- "$@" --data-urlencode "database=$database"
  request_get "metadata/export" "$@"
}

parse_ddl() {
  database=""
  table_name=""
  table_id=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --database) database="${2:-}"; shift 2 ;;
      --table) table_name="${2:-}"; shift 2 ;;
      --table-id) table_id="${2:-}"; shift 2 ;;
      *) echo "unknown ddl arg: $1" >&2; usage ;;
    esac
  done

  set --
  [ -n "$database" ] && set -- "$@" --data-urlencode "database=$database"
  [ -n "$table_name" ] && set -- "$@" --data-urlencode "table=$table_name"
  [ -n "$table_id" ] && set -- "$@" --data-urlencode "tableId=$table_id"
  request_get "metadata/ddl" "$@"
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

parse_read_query() {
  database=""
  sql=""
  preferred_engine=""
  limit=""
  timeout_seconds=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --database) database="${2:-}"; shift 2 ;;
      --sql) sql="${2:-}"; shift 2 ;;
      --preferred-engine|--engine) preferred_engine="${2:-}"; shift 2 ;;
      --limit) limit="${2:-}"; shift 2 ;;
      --timeout-seconds) timeout_seconds="${2:-}"; shift 2 ;;
      *) echo "unknown read-query arg: $1" >&2; usage ;;
    esac
  done

  [ -n "$database" ] || { echo "--database is required" >&2; usage; }
  [ -n "$sql" ] || { echo "--sql is required" >&2; usage; }

  payload="{\"database\":\"$(json_escape "$database")\",\"sql\":\"$(json_escape "$sql")\""
  [ -n "$preferred_engine" ] && payload="$payload,\"preferredEngine\":\"$(json_escape "$preferred_engine")\""
  [ -n "$limit" ] && payload="$payload,\"limit\":$limit"
  [ -n "$timeout_seconds" ] && payload="$payload,\"timeoutSeconds\":$timeout_seconds"
  payload="$payload}"

  request_post_json "query/read" "$payload"
}

require_env ODW_AGENT_API_BASE_URL "$BASE_URL"
require_env ODW_AGENT_SERVICE_TOKEN "$SERVICE_TOKEN"

subcommand="${1:-}"
[ -n "$subcommand" ] || usage
shift || true

case "$subcommand" in
  inspect) parse_inspect "$@" ;;
  lineage) parse_lineage "$@" ;;
  resolve-datasource) parse_resolve_datasource "$@" ;;
  export) parse_export "$@" ;;
  ddl) parse_ddl "$@" ;;
  read-query) parse_read_query "$@" ;;
  -h|--help|help) usage ;;
  *) echo "unknown subcommand: $subcommand" >&2; usage ;;
esac
